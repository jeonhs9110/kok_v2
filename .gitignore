# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# scratch / asset drops not for the repo
/src/0508/

# local-only sibling folders (private notes, credentials, drafts — never commit)
/aws-credentials/
/claude-memory/
/docs/
/email-drafts/
# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# terraform — state files contain secrets and resource IDs, never commit
**/*.tfstate
**/*.tfstate.*
**/.terraform/
**/.terraform.lock.hcl
**/*.tfvars
**/*.tfvars.json
!**/*.tfvars.example
