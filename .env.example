# KOKKOK Garden — environment variables
#
# Copy to .env.local for development (auto-loaded by Next.js).
# Production: these are baked into /etc/kokkok/env on the EC2 instance
# via terraform variables (see infrastructure/ec2.tf user_data).
#
# Round 31: kept in sync with actual reads across src/. Handoff engineer
# should be able to grep `process.env\.` to reconcile against this file.

# === Database (AWS RDS Postgres 16) ===
# Connection string. Read by src/lib/db/pool.ts.
# Format: postgresql://USER:PASS@HOST:5432/DBNAME?sslmode=require
# Prod: assembled at EC2 boot from Secrets Manager.
DATABASE_URL=

# Server-side dispatcher flag — when "true", every src/lib/api/* + src/app/api/*
# read/write routes through src/lib/db/* (pg) instead of any legacy path.
# Production: always "true".
# Whitespace / case insensitive as of R31 (` true `, `TRUE`, `true\n` all work).
USE_RDS=true

# Browser-side mirror of USE_RDS — baked into the client bundle at
# build time. Admin client hooks (useProducts, useCarousel, etc.) read
# this via src/lib/admin/rdsFlag.ts to decide whether to POST to
# /api/admin/* (RDS) or call the Supabase JS client directly. MUST be
# flipped together with USE_RDS at deploy time; otherwise admin writes
# silently land in the wrong store.
NEXT_PUBLIC_USE_RDS=true

# === AWS Cognito (authentication) ===
USE_COGNITO=true
NEXT_PUBLIC_USE_COGNITO=true
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# AWS region for Cognito + S3 SDKs. Falls back to ap-northeast-2 when
# unset. Set explicitly on cross-region deploys.
AWS_REGION=ap-northeast-2

# === S3 + CloudFront (media storage) ===
USE_S3=true
NEXT_PUBLIC_USE_S3=true
S3_STORAGE_BUCKET=kokkok-media
S3_PUBLIC_CDN_URL=https://www.kokkokgarden.com/media
NEXT_PUBLIC_S3_STORAGE_BUCKET=kokkok-media
NEXT_PUBLIC_S3_PUBLIC_CDN_URL=https://www.kokkokgarden.com/media

# === Supabase (legacy — retained ONLY for /auth/callback stale-link handling) ===
# Post-2026-06-27 cutover these are no longer required for reads/writes;
# every app path routes through RDS + Cognito + S3. Leave unset in new
# environments — /auth/callback will just 302 stale legacy links to
# /login?error=link-expired.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === OpenAI (chatbot + translation) ===
# Used by /api/chat AND src/lib/openai.ts (/en, /cn, /jp, /vn, /th product
# translation). Without this, /en pages render untranslated Korean copy
# and the chatbot returns fallback strings. Format: sk-... (R31 validates
# `/^sk-[A-Za-z0-9_-]{20,}$/`; a stray whitespace or the placeholder
# `sk-...` here is treated as unset with an explicit error log).
OPENAI_API_KEY=sk-...

# === Analytics IP salt ===
# Salt mixed into the SHA-256 IP hash before persisting to
# public.analytics.ip_hash. Without it, /api/track logs a startup
# error in production and SKIPS the ip_hash column (rather than
# persist a reversible hash from the hardcoded fallback). Generate
# one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ANALYTICS_IP_SALT=

# === CSRF ===
# Optional. Additional origins allowed through assertSameOrigin, on top
# of the two hardcoded production hosts. Comma-separated list; each
# entry must start with https:// (or http://localhost: for local
# tunnels). Malformed entries are dropped with a startup warn.
# Example: https://staging.kokkokgarden.com,https://preview.kokkokgarden.com
CSRF_ALLOWED_ORIGIN=

# === Public site URL ===
# Used by src/app/auth/callback/route.ts when the ALB forwards no host
# header (rare — only fires on misconfigured Cloudfront behaviors).
# Should equal the current environment's canonical URL.
NEXT_PUBLIC_SITE_URL=https://www.kokkokgarden.com

# === Development / diagnostics ===
# `ANALYZE=true` runs next.config.ts through @next/bundle-analyzer at
# build time. Not needed in prod.
ANALYZE=false
