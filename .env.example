# KOKKOK Garden — environment variables
#
# Copy to .env.local for development (auto-loaded by Next.js).
# Production: these are baked into /etc/kokkok/env on the EC2 instance
# via terraform variables (see infrastructure/ec2.tf user_data).

# === Database (AWS RDS Postgres 16) ===
# Connection string. Read by src/lib/db/pool.ts.
# Format: postgresql://USER:PASS@HOST:5432/DBNAME?sslmode=require
# Prod: assembled at EC2 boot from Secrets Manager.
DATABASE_URL=

# Server-side dispatcher flag — when "true", every src/lib/api/* + src/app/api/*
# read/write routes through src/lib/db/* (pg) instead of any legacy path.
# Production: always "true".
USE_RDS=true

# Browser-side mirror of USE_RDS — baked into the client bundle at
# build time. Admin client hooks (useProducts, useCarousel, etc.) read
# this via src/lib/admin/rdsFlag.ts to decide whether to POST to
# /api/admin/* (RDS) or call the Supabase JS client directly. MUST be
# flipped together with USE_RDS at deploy time; otherwise admin writes
# silently land in the wrong store.
NEXT_PUBLIC_USE_RDS=true

# === AWS Cognito (authentication) ===
USE_COGNITO=true
NEXT_PUBLIC_USE_COGNITO=true
COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-northeast-2_XXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX

# === S3 + CloudFront (media storage) ===
USE_S3=true
NEXT_PUBLIC_USE_S3=true
S3_STORAGE_BUCKET=kokkok-media
S3_PUBLIC_CDN_URL=https://www.kokkokgarden.com/media
NEXT_PUBLIC_S3_STORAGE_BUCKET=kokkok-media
NEXT_PUBLIC_S3_PUBLIC_CDN_URL=https://www.kokkokgarden.com/media

# === OpenAI (chatbot) ===
# Used by /api/chat. Without this, the chatbot returns 503 "service
# temporarily unavailable" — every other surface keeps working.
OPENAI_API_KEY=sk-...

# === Analytics IP salt ===
# Salt mixed into the SHA-256 IP hash before persisting to
# public.analytics.ip_hash. Without it, /api/track logs a startup
# warning and falls back to a low-entropy literal — the hash becomes
# trivially reversible. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ANALYTICS_IP_SALT=
