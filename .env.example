# KOKKOK Garden — environment variables
#
# Copy to .env.local for development (auto-loaded by Next.js).
# Production: set the same keys in Vercel (storefront SSR) AND on the EC2
# instance's systemd env file (admin SSR). Missing any of the NEXT_PUBLIC_*
# pair causes the storefront to render empty (audit 2026-06-21 — admin
# pages render but show "Supabase 클라이언트 없음" toasts).

# === Required for the storefront + admin ===
# Public Supabase URL. Inlined at build time, so changing it requires a rebuild.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key from Project Settings → API. Public — RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# === Server-side only ===
# Service-role key — bypasses RLS. ONLY used in route handlers under
# src/app/api/ that need to read across users (analytics aggregations, etc.).
# Never expose to the client; never log.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# OpenAI key for the in-admin chatbot lead capture (/api/chat/...).
# Optional — chatbot will throw if unset, but other admin flows work.
OPENAI_API_KEY=sk-...

# Salt mixed into the SHA-256 IP hash before persisting to
# public.analytics.ip_hash. Without it, /api/track logs a startup
# warning and falls back to a low-entropy literal — the hash becomes
# trivially reversible (every salt value is in the source). Set in EC2
# user-data; rotate to invalidate every historical ip_hash row.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ANALYTICS_IP_SALT=

# === RDS migration (Phase C/D/E in progress) ===
# Direct Postgres connection string. Read by src/lib/db/pool.ts. Required
# on EC2 once any USE_RDS code path is reachable; required locally only
# for testing the pg implementations during development.
# Format: postgresql://USER:PASS@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# Feature flag: when "true", service modules dispatch reads/writes to
# RDS via src/lib/db/* instead of Supabase. Stays "false" through
# Phase C/D development; flipped to "true" at Phase F cutover.
USE_RDS=false

# Cognito user pool config (filled in from terraform outputs once
# Phase D wires the middleware to verify Cognito JWTs instead of
# Supabase ones).
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_CLIENT_ID=
